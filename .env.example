# AI·SW 마에스트로 멘토 자동화 — 환경 변수
# 실제 값을 채운 뒤 이 파일을 .env 로 복사하세요. (.env 는 커밋 금지)

ASM_SEOUL_HOMEPAGE_URL=http://swmaestro.ai/
ASM_BUSAN_HOMEPAGE_URL=http://swmaestro.ai/busan
ASM_HOMEPAGE_ID=your-id@example.com
ASM_HOMEPAGE_PW=your-password

# 부산 숙박예약(swmaestro.ai/booking) 전용 비밀번호. 메인 사이트와 별도 로그인이며, 이 값을 로그인과
# 최초 비밀번호 생성 양쪽에 그대로 쓴다. 비워두면 최초 로그인 시 회원정보의 연락처 뒤 4자리로 임시
# 로그인만 시도하고, 비밀번호 생성 단계는 값이 없으면 자동화를 멈추고 이 값을 채우도록 요청한다.
ASM_BUSAN_STAY_BOOKIN_PW=

# --- 선택(optional) ---
# 런타임 데이터(세션/override/recon/아티팩트) 저장 위치. 미지정 시: 개발=레포 .agentdocs/asm,
# 그 외=${XDG_STATE_HOME:-~/.local/state}/asm-mentor. 플러그인/cron 배포 시 쓰기 가능한 경로로 지정.
# ASM_STATE_DIR=/path/to/writable/state
# 자가 복구(self-heal) 끄기: 0 이면 끔(기본 ON). 명령별로는 --no-heal.
# ASM_AUTO_HEAL=0
# 브라우저 옵션: ASM_HEADFUL=1 (창 표시), ASM_BROWSER_CHANNEL=chrome|msedge|...
# ASM_HEADFUL=1
